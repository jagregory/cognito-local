{
  "name": "cognito-local-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cognito:build": "docker compose build --no-cache",
    "cognito:start": "docker compose up -d --build",
    "cognito:stop": "docker compose down",
    "cognito:setup": "bash scripts/setup-cognito.sh",
    "cognito:reset": "docker compose down && rm -rf .cognito/db && npm run cognito:start && sleep 2 && npm run cognito:setup",
    "dev:full": "npm run cognito:start && sleep 2 && npm run cognito:setup && npm run dev"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.7.2",
    "@aws-amplify/ui-react": "^6.15.2",
    "aws-amplify": "^6.16.3",
    "aws-jwt-verify": "^5.1.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
